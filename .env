# file ~/Sites/blog/.env
# main conf file (blueprint)
# this file contains APP_SECRET=change_me (a generic placeholder). it is committed to git, so the structure is known.

APP_NAME=blog
APP_SHARE_DIR=var/share

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://user:pass@host:3306/db?serverVersion=10.5"
###< doctrine/doctrine-bundle ###

MAILER_DSN=null://default

JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
AUTH_JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem

###> custom/parameters ###
CDN=https://cdn.pendoncete.org
###< custom/parameters ###
