# file ~/Sites/blig/.env
# main conf file (blueprint)
# this file should be commited to Git, so the structure is known.

### > symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
### < symfony/framework-bundle ###

### > doctrine/doctrine-bundle ###
DATABASE_URL="mysql://db_user:db_password@127.0.0.1:3306/db_name?serverVersion=10.5"
### < doctrine/doctrine-bundle ###

### > symfony/messenger ###
MESSENGER_TRANSPORT_DSN=sync://
# I could't manage to set an async configuration. some of the approaches I tried were:
#MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
#MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0&get_notify_timeout=0
#MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0&get_notify_timeout=0&check_delayed_interval=5000
# but none of them worked; I always get: PDOException (42000)]
#  SQLSTATE[42000]: Syntax error or access violation: 1064 You have an error in
#   your SQL syntax; check the manual that corresponds to your MariaDB server v
#  ersion for the right syntax to use near 'SKIP LOCKED' at line 1
### < symfony/messenger ###

### > symfony/mailer ###
MAILER_DSN=null://default
### < symfony/mailer ###

### > JWT & SSO ###
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=
AUTH_JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_COOKIE_DOMAIN=
CORS_ALLOW_ORIGIN=

AUTH_BASE_URL=
APP_CALLBACK_URL=

TRUSTED_PROXIES=
TRUSTED_HOSTS=
### < JWT & SSO ###

### > External APIs ###
GOOGLE_MAPS_API_KEY=
OPEN_ROUTER_API_KEY=
### < External APIs ###

###> custom/parameters ###
CDN=https://cdn.pendoncete.org
###< custom/parameters ###
