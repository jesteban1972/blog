{# file ~/Sites/blog/templates/app/base.html.twig #}

{% set is_rtl = app.request.locale in ['ar', 'he'] %}

<!DOCTYPE html>
<html lang="{{ app.request.locale }}" {% if is_rtl %}dir="rtl"{% endif %}>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    {# SEO & social meta tags #}
    <title>{% block title %}{{ app_domain }}{% endblock %}</title>
    <meta name="description" content="{% block description %}{{ 'homepage.description' | trans }}{% endblock %}">
    <meta name="keywords" content="{% block keywords %}Pendoncete, blog.pendoncete.org, annales sex diary{% endblock %}">
    <meta name="robots" content="index, follow">
    <meta name="author" content="Pendoncete">
    <link rel="publisher" href="https://blog.pendoncete.org">
    <meta property="og:site_name" content="blog.pendoncete.org">
    {% if app.request.attributes.get('_route') %}
        <link rel="canonical" href="{{ url(app.request.attributes.get('_route'), app.request.attributes.get('_route_params')) }}">
    {% endif %}

    {# assets #}
    <link rel="icon" type="image/x-icon" href="{{ asset('images/icons/favicon.ico', 'cdn') }}">
    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('vendor/bootstrap/dist/css/bootstrap.min.css') }}">
        <link rel="stylesheet" href="{{ asset('vendor/@fortawesome/fontawesome-free/css/all.min.css') }}">
        <link rel="stylesheet" href="{{ asset('styles/entrypoint.css') }}">
    {% endblock %}

    {# TODO: ad networks scripts (e.g. Google AdSense) #}
    {# place my 'Auto-Ads' script here, once I get approved #}
</head>

<body>

{% include 'app/_age_verification.html.twig' %}

<header>
    {% include 'app/_header.html.twig' %}
</header>

<!-- Bootstrap 5 responsive design -->
<div class="main-wrapper">

    {# main contents #}
    <main>
        {% block main %}{% endblock %}
    </main>

    <aside>
        {% block aside %}
{#            {% include '_aside.html.twig' %}#}
        {% endblock %}
    </aside>

</div>

<!-- mobile sidebar offcanvas -->
<div class="offcanvas offcanvas-start" tabindex="-1" id="aside-mobile">

    <div class="offcanvas-header">
        <button
            type="button"
            class="btn-close"
            data-bs-dismiss="offcanvas"
            aria-label="Close"
            title="{{ 'sidebar.close_sidebar' | trans }}"
        >
        </button>
    </div>

    <div class="offcanvas-body">

        {# sidebar #}
{#        {% include '_aside.html.twig' %}#}

    </div>

</div>

<footer>
    {% include 'app/_footer.html.twig' %}
</footer>

{% block javascripts %}
    {{ importmap((['app', 'language-bar', 'age-verification'])) }}

    <!-- SEO script(s) -->
    {% block seo_script %}
        <script type="application/ld+json">
            {
                  "@context": "https://schema.org",
                  "@type": "WebPage",
                  "name": "{% block page_name %}{{ app_domain }}{% endblock %}",
                        "description": "{% block page_description %}{{ app_domain }}{% endblock %}",
                        "author": {
                          "@type": "Person",
                          "name": "Pendoncete"
                        },
                        "publisher": {
                            "@type": "Organization",
                            "name": "blog.pendoncete.org",
                            "url": "https://blog.pendoncete.org",
                            "logo": {
                                "@type": "ImageObject",
                                "url": "{{ asset('images/artwork/chameleon.png', 'cdn') }}"
                            }
                        }
                  }
        </script>
    {% endblock %}

{% endblock %}

</body>
</html>
