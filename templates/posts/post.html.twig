{# file ~/Sites/blog/templates/posts/post.html.twig #}

{% extends 'app/base.html.twig' %}

{% block title %}
    {{ post.title }}
{% endblock %}

{% block main %}
    <div class="post-detail-container">

        {# main article content #}
        <article class="blog-post">
            <header class="post-header">
                <h1 class="post-title">{{ post.title }}</h1>
                <div class="post-metadata">
                <span class="post-date">
                    {{ post.createdAt|date('y-m-d H:i') }}
                </span>
                    {% if post.category?.name %}
                        <span class="metadata-separator">•</span>
                        <span class="post-category">
                        <a href="#" class="category-link">
                            {{ post.category.name }}
                        </a>
                    </span>
                    {% endif %}
                </div>
            </header>

            <hr class="section-divider" />

            <section class="post-body">
                {{ post.content|nl2br }}
            </section>
        </article>

        <hr class="section-divider" />

        {# community comments section #}
        {% if comments is not empty %}
            <section id="section-community-comments" class="entity-community-comments">
                <div class="community-section">
                    <h2 class="community-section-title">
                        {{ 'community comments'|trans }}
                    </h2>
                    <div class="community-comments-list">
                        {% for comment in comments %}
                            {{ include('posts/_comment_preview.html.twig', {'comment': comment}) }}
                        {% endfor %}
                    </div>
                </div>
            </section>
        {% endif %}
    </div>
{% endblock %}
